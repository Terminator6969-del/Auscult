# Copy this file to `backend/.env.local` and fill in the values.
# The backend reads these at startup — restart the server after editing.
#
# WARNING: .env.local is gitignored. Never commit API keys.

# ── Anthropic API key (REQUIRED for Managed Agent attending grading) ──
# The medkit-attending Managed Agent uses Opus 4.7 for clinical reasoning.
# This is the ONE paid dependency. The Managed Agent infrastructure
# (session management, custom tools, SSE event streaming) has no free equivalent.
ANTHROPIC_API_KEY=

# ── OpenRouter API key (OPTIONAL — enables free/cheap patient LLM) ──
# Enables both the voice agent and text-chat to use free models
# (e.g. deepseek-v4-flash, llama-3.3-70b) instead of Claude Haiku 4.5.
# Sign up at https://openrouter.ai/keys (no credit card required for free models).
# When unset, falls back to ANTHROPIC_API_KEY for the patient persona.
OPENROUTER_API_KEY=
# Optional: override the default free model.
# OPENROUTER_VOICE_MODEL=deepseek/deepseek-v4-flash:free
# OPENROUTER_PATIENT_MODEL=deepseek/deepseek-v4-flash:free

# Cached IDs for the persistent Managed Agent + Environment.
# First run: leave these blank, start the server, POST /agent/bootstrap,
# then paste the returned `agent_id` / `environment_id` back here and
# restart. Subsequent runs are no-ops.
MEDKIT_AGENT_ID=
MEDKIT_ENV_ID=

# LiveKit Cloud — https://cloud.livekit.io. Used by the FastAPI server
# to mint room JWTs and by voice_agent.py to register as a worker.
# Free tier: 50GB egress, 3000 minutes/month. Enough for extensive testing.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Deepgram — https://deepgram.com. Streaming STT inside the voice worker.
# $200 free credit on signup. After that, Nova-3 is $0.0059/min.
DEEPGRAM_API_KEY=

# Cartesia — https://cartesia.ai. Streaming TTS inside the voice worker.
# Free credit on signup. After that, Sonic-2 is ~$0.10/1M characters.
CARTESIA_API_KEY=
